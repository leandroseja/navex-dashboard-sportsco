    {
      "parameters": {
        "jsCode": "const dados = $('Buscar Inativos 15min').item.json;\nconst psid = dados.telefone;\nconst nome = dados.nome || 'Ola';\nconst token = dados.ig_token;\n\nif (!token) {\n  console.error('Token Instagram nao encontrado para empresa: ' + dados.empresa);\n  return [{ json: { ...dados, envioInstagram: { erro: 'token_nao_encontrado' } } }];\n}\n\nconst texto = nome + ', obrigada pelo contato!\\n\\nPara ficar por dentro das novidades, lancamentos e tudo sobre o mundo das motos, envie seu numero de WhatsApp (DDD + telefone) e receba conteudos exclusivos em primeira mao!';\n\nconst response = await this.helpers.httpRequest({\n  method: 'POST',\n  url: 'https://graph.instagram.com/v21.0/me/messages',\n  headers: { 'Content-Type': 'application/json' },\n  body: JSON.stringify({\n    recipient: { id: psid },\n    message: { text: texto },\n    access_token: token\n  })\n});\n\nreturn [{ json: { ...dados, envioInstagram: response } }];"
      },
