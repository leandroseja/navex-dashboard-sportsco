      "parameters": {
        "jsCode": "const cliente = $('Buscar Inativos MySQL').first().json;\nconst resposta = $('Buscar Resposta').first().json;\nconst mensagem = (resposta.mensagem_cliente || '').trim();\n\nconsole.log('Mensagem recebida:', mensagem);\n\n// Regex para email (pega no meio do texto)\nconst emailRegex = /[^\\s@]+@[^\\s@]+\\.[^\\s@]+/;\nconst matches = mensagem.match(emailRegex);\n\nconst emailValido = matches && matches.length > 0;\nconst email = emailValido ? matches[0] : '';\n\nconsole.log('Email válido?', emailValido);\nconsole.log('Email:', email);\n\nreturn [{\n  json: {\n    ...cliente,\n    emailValido: emailValido,\n    email: email\n  }\n}];"
